{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "telemetry-cluster": { "Destinations": { "d1": { "Address": "http://telemetry-api:8080" } } },
      "device-cluster": { "Destinations": { "d1": { "Address": "http://device-api:8080" } } },
      "control-cluster": { "Destinations": { "d1": { "Address": "http://control-api:8080" } } },
      "identity-cluster": { "Destinations": { "d1": { "Address": "http://identity-api:8080" } } },
      "notification-cluster": { "Destinations": { "d1": { "Address": "http://notification-api:8080" } } }
    },
    "Routes": {
      "telemetry-route": {
        "ClusterId": "telemetry-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/telemetry/{**remainder}" }
      },
      "telemetry-swagger": {
        "ClusterId": "telemetry-cluster",
        "Match": { "Path": "/swagger-docs/telemetry/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-docs/telemetry" }
        ]
      },
      "device-route": {
        "ClusterId": "device-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/device/{**remainder}" }
      },
      "device-swagger": {
        "ClusterId": "device-cluster",
        "Match": { "Path": "/swagger-docs/device/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-docs/device" }
        ]
      },
      "control-route": {
        "ClusterId": "control-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/control/{**remainder}" }
      },
      "control-swagger": {
        "ClusterId": "control-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/swagger-docs/control/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-docs/control" }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identity/{**remainder}" }
      },
      "identity-swagger": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/swagger-docs/identity/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-docs/identity" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/notification/{**remainder}" }
      },
      "notification-swagger": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/swagger-docs/notification/{**remainder}" },
        "Transforms": [
          { "PathRemovePrefix": "/swagger-docs/notification" }
        ]
      }
    }
  },
  "JwtOptions": {
    "SecretKey": "super-secret-key-must-be-at-least-32-characters-long",
    "Issuer": "AquaSmart.Identity",
    "Audience": "AquaSmart.Gateway",
    "ExpiresHours": 12
  }
}
